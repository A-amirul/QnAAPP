@model QnAApp.Domain.Entities.Comment

<div style="margin-left:20px;">
    💬 @Model.Content

    <br />
    <small>
        @Model.CreatedAt.ToString("dd MMM yyyy hh:mm tt")
        @if (Model.UpdatedAt != null)
        {
            <span>| Edited: @Model.UpdatedAt.Value.ToString("dd MMM yyyy hh:mm tt")</span>
        }
    </small>
</div>